BEAUTY CHECK
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GCTU | Visual Recognition Lab</title>
    <style>
        :root {
            --gold: #d4af37;
            --dark: #0a0a0a;
            --glass: rgba(255, 255, 255, 0.05);
        }

        body {
            background-color: var(--dark);
            color: #fff;
            font-family: 'Inter', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }

        #scanner-box {
            border: 1px solid var(--gold);
            padding: 40px;
            background: var(--glass);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            text-align: center;
            box-shadow: 0 0 30px rgba(212, 175, 55, 0.2);
            width: 85%;
            max-width: 400px;
        }

        .scan-line {
            width: 100%;
            height: 2px;
            background: var(--gold);
            position: relative;
            animation: scan 2s infinite ease-in-out;
            box-shadow: 0 0 15px var(--gold);
        }

        @keyframes scan {
            0%, 100% { top: 0; }
            50% { top: 100px; }
        }

        .stats {
            text-align: left;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            margin-top: 20px;
            color: #aaa;
        }

        .highlight { color: var(--gold); font-weight: bold; }

        button {
            background: transparent;
            color: var(--gold);
            border: 1px solid var(--gold);
            padding: 12px 24px;
            margin-top: 30px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: 0.3s;
        }

        button:hover { background: var(--gold); color: #000; }

        .hidden { display: none; }
        
        #final-message {
            animation: fadeIn 1.5s ease-in;
        }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body>

    <div id="scanner-box">
        <div id="init-view">
            <h2 style="letter-spacing: 3px;">AESTHETIC SCANNER</h2>
            <div style="height: 100px; border: 1px dashed var(--gold); margin: 20px 0; position: relative;">
                <div class="scan-line"></div>
            </div>
            <p style="font-size: 12px; color: #888;">DETECTING NEW STYLE ELEMENTS...</p>
            <button onclick="startScan()">Analyze Style</button>
        </div>

        <div id="loading-view" class="hidden">
            <p>Processing High-Res Details...</p>
            <div class="stats" id="stats-log"></div>
        </div>

        <div id="final-message" class="hidden">
            <span style="font-size: 50px;">✨</span>
            <h2 style="color: var(--gold);">SCAN COMPLETE</h2>
            <p style="line-height: 1.6;">
                System confirms: The new braids are a <span class="highlight">10/10 masterpiece</span>. 
                <br><br>
                It’s not just the hair, though—it’s the way they frame your face. You look absolutely stunning.
            </p>
            <p style="font-size: 12px; color: #888; margin-top: 20px;">Report generated by: Sefa</p>
        </div>
    </div>

    <script>
        function startScan() {
            document.getElementById('init-view').classList.add('hidden');
            document.getElementById('loading-view').classList.remove('hidden');
            
            const log = document.getElementById('stats-log');
            const lines = [
                "> Detecting hair symmetry...",
                "> Analyzing braid precision...",
                "> Calculating glow levels...",
                "> Error: Beauty levels exceeding system limits.",
                "> Finalizing compliment.exe..."
            ];

            let i = 0;
            const interval = setInterval(() => {
                const p = document.createElement('p');
                p.innerText = lines[i];
                log.appendChild(p);
                i++;
                if (i >= lines.length) {
                    clearInterval(interval);
                    setTimeout(showFinal, 1000);
                }
            }, 800);
        }

        function showFinal() {
            document.getElementById('loading-view').classList.add('hidden');
            document.getElementById('final-message').classList.remove('hidden');
            document.body.style.background = "radial-gradient(circle, #1a1a1a 0%, #000 100%)";
        }
    </script>
</body>
</html>
